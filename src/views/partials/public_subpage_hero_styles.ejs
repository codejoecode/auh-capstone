<%- include("./immersive_hero_styles") %>

    .subpage-hero {
      display: flex;
      min-height: 100vh;
      align-items: flex-end;
      padding: 148px 20px 88px;
    }

    .subpage-hero::after {
      position: absolute;
      right: 0;
      bottom: 0;
      left: 0;
      height: 132px;
      background: linear-gradient(to bottom, rgba(5, 5, 5, 0), rgba(5, 5, 5, 0.92));
      content: "";
      pointer-events: none;
      z-index: 1;
    }

    .subpage-hero__content {
      position: relative;
      z-index: 2;
      width: min(1120px, 100%);
      margin: 0 auto;
      color: #f4f1ec;
    }

    .subpage-hero__eyebrow {
      margin: 0 0 16px;
      color: rgba(244, 241, 236, 0.58);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .subpage-hero__title {
      max-width: 10em;
      margin: 0;
      font-size: clamp(2.4rem, 8vw, 6rem);
      font-weight: 400;
      letter-spacing: 0.12em;
      line-height: 0.96;
      text-transform: uppercase;
      text-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
    }

    .subpage-hero__text {
      width: min(560px, 100%);
      margin: 20px 0 0;
      color: rgba(244, 241, 236, 0.78);
      font-size: 0.98rem;
      line-height: 1.7;
      text-shadow: 0 3px 18px rgba(0, 0, 0, 0.46);
    }

    .subpage-hero__anchor {
      position: absolute;
      left: 50%;
      bottom: 28px;
      z-index: 2;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-decoration: none;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.8);
      text-transform: uppercase;
      transform: translateX(-50%);
      transition: opacity 180ms ease, color 180ms ease;
    }

    .subpage-hero__anchor:hover,
    .subpage-hero__anchor:focus-visible {
      opacity: 1;
      color: #fff;
    }

    .subpage-content {
      background: #050505;
      padding: 72px 18px 88px;
    }

    .subpage-content__inner {
      width: min(1120px, 100%);
      margin: 0 auto;
    }

    @media (max-width: 820px) {
      .subpage-hero {
        min-height: 100vh;
        padding: 128px 18px 82px;
      }

      .subpage-hero__title {
        max-width: 12em;
      }
    }

    @media (max-width: 560px) {
      .subpage-hero {
        padding-top: 112px;
      }

      .subpage-content {
        padding-top: 60px;
      }
    }
