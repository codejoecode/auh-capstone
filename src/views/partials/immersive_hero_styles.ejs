    .immersive-hero {
      position: relative;
      min-height: 100vh;
      height: 100vh;
      overflow: hidden;
      isolation: isolate;
      background: #000;
    }

    .immersive-hero__video,
    .immersive-hero__shade,
    .immersive-hero__noise {
      position: absolute;
      inset: 0;
    }

    .immersive-hero__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(0.72) contrast(1.1) brightness(0.74);
      transform: scale(1.03);
      z-index: -3;
    }

    .immersive-hero__shade {
      background: rgba(0, 0, 0, 0.62);
      z-index: -2;
    }

    .immersive-hero__noise {
      background-image: url("/images/animatedBackground.gif");
      background-repeat: repeat;
      opacity: 0.13;
      mix-blend-mode: screen;
      z-index: -1;
      pointer-events: none;
    }
