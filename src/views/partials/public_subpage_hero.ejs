<section class="subpage-hero immersive-hero" aria-label="<%= heroAriaLabel %>">
  <video class="subpage-hero__video immersive-hero__video" autoplay muted loop playsinline aria-hidden="true">
    <source src="/videos/auhVHS3.mp4" type="video/mp4" />
  </video>

  <div class="subpage-hero__shade immersive-hero__shade" aria-hidden="true"></div>
  <div class="subpage-hero__noise immersive-hero__noise" aria-hidden="true"></div>

  <div class="subpage-hero__content">
    <p class="subpage-hero__eyebrow"><%= heroEyebrow %></p>
    <h1 class="subpage-hero__title"><%= heroTitle %></h1>
    <% if (heroText) { %>
      <p class="subpage-hero__text"><%= heroText %></p>
    <% } %>
  </div>

  <a href="#page-content" class="subpage-hero__anchor"><%= heroAnchorLabel || "Explore" %></a>
</section>
