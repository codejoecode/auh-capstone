<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style id="site-page-styles">
<%- include("../partials/public_page_styles") %>
<%- include("../partials/immersive_hero_styles") %>

    .newsletter-page {
      position: relative;
      background: #050505;
    }

    .newsletter-experience {
      position: relative;
      min-height: 100vh;
    }

    .newsletter-experience__backdrop {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      background: #000;
    }

    .newsletter-experience__backdrop::after {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(0, 0, 0, 0.28), transparent 38%, rgba(0, 0, 0, 0.36));
      content: "";
      z-index: -1;
      pointer-events: none;
    }

    .newsletter-experience__content {
      position: relative;
      z-index: 2;
      width: min(1180px, calc(100% - 40px));
      margin: -100vh auto 0;
      padding: 136px 0 96px;
    }

    .newsletter-intro {
      width: min(760px, 100%);
      margin-bottom: 32px;
    }

    .newsletter-intro__title {
      max-width: 9em;
      margin: 0;
      font-size: clamp(2.5rem, 8vw, 6.2rem);
      font-weight: 400;
      letter-spacing: 0.12em;
      line-height: 0.95;
      text-transform: uppercase;
      text-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
    }

    .newsletter-panel {
      width: min(640px, 100%);
      padding: 32px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.04);
      box-shadow: 0 20px 70px rgba(0, 0, 0, 0.22);
    }

    .newsletter-heading {
      margin: 0 0 24px;
      color: rgba(244, 241, 236, 0.72);
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.32em;
      text-align: center;
      text-transform: uppercase;
    }

    .newsletter-status,
    .newsletter-copy {
      margin: 0 0 20px;
      color: rgba(244, 241, 236, 0.78);
      text-align: center;
    }

    .newsletter-form {
      display: grid;
      gap: 16px;
    }

    .newsletter-form label {
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }

    .newsletter-form input {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid rgba(255, 255, 255, 0.22);
      background: rgba(0, 0, 0, 0.28);
      color: #f4f1ec;
      font: inherit;
    }

    .newsletter-form button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 10px 22px;
      border: 1px solid currentColor;
      border-radius: 4px;
      background: transparent;
      color: #f4f1ec;
      font: inherit;
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 180ms ease, color 180ms ease, opacity 180ms ease;
    }

    .newsletter-form button:hover,
    .newsletter-form button:focus-visible {
      background: #fff;
      color: #050505;
    }

    @media (max-width: 820px) {
      .newsletter-experience__content {
        width: min(calc(100% - 28px), 1180px);
        padding-top: 122px;
      }
    }

    @media (max-width: 640px) {
      .newsletter-experience__backdrop {
        position: absolute;
        inset: 0 0 auto 0;
        height: 100vh;
      }

      .newsletter-experience__content {
        margin-top: 0;
        padding-top: 108px;
      }

      .newsletter-intro {
        margin-bottom: 24px;
      }

      .newsletter-intro__title {
        max-width: 100%;
        font-size: clamp(2.2rem, 14vw, 4rem);
      }

      .newsletter-panel {
        padding: 24px 18px;
      }
    }
  </style>
</head>
<body class="public-page-template" data-shell-page="public">
  <%- include("../partials/header") %>
  <main id="site-shell-content" class="newsletter-page">
    <section class="newsletter-experience" aria-labelledby="newsletter-title">
      <div class="newsletter-experience__backdrop immersive-hero" aria-hidden="true">
        <video class="immersive-hero__video" autoplay muted loop playsinline>
          <source src="/videos/auhVHS6.mp4" type="video/mp4" />
        </video>
        <div class="immersive-hero__shade"></div>
        <div class="immersive-hero__noise"></div>
      </div>

      <div class="newsletter-experience__content">
        <section class="newsletter-intro">
          <h1 id="newsletter-title" class="newsletter-intro__title">Newsletter</h1>
        </section>

        <section id="page-content" aria-labelledby="newsletter-heading">
          <div class="newsletter-panel">
            <h2 id="newsletter-heading" class="newsletter-heading">Stay In The Loop</h2>

            <% if (status) { %>
              <p class="newsletter-status"><%= status %></p>
            <% } else { %>
              <p class="newsletter-copy">Sign up for release announcements, ticket drops, and future updates.</p>
            <% } %>

            <form action="/newsletter" method="POST" class="newsletter-form">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" required>
              <button type="submit">Sign Up</button>
            </form>
          </div>
        </section>
      </div>
    </section>
  </main>
  <%- include("../partials/public_shell_bootstrap") %>
</body>
</html>
