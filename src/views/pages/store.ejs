<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style id="site-page-styles">
<%- include("../partials/public_page_styles") %>
<%- include("../partials/immersive_hero_styles") %>

    .store-page {
      position: relative;
      background: #050505;
    }

    .store-experience {
      position: relative;
      min-height: 100vh;
    }

    .store-experience__backdrop {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      background: #000;
    }

    .store-experience__backdrop::after {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(90deg, rgba(0, 0, 0, 0.26), transparent 38%, rgba(0, 0, 0, 0.34));
      content: "";
      z-index: -1;
      pointer-events: none;
    }

    .store-experience__content {
      position: relative;
      z-index: 2;
      width: min(1180px, calc(100% - 40px));
      margin: -100vh auto 0;
      padding: 136px 0 96px;
    }

    .store-intro {
      width: min(760px, 100%);
      margin-bottom: 40px;
    }

    .store-intro__eyebrow,
    .store-card__meta {
      margin: 0;
      color: rgba(244, 241, 236, 0.58);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .store-intro__title {
      max-width: 9em;
      margin: 0;
      font-size: clamp(2.5rem, 8vw, 6.2rem);
      font-weight: 400;
      letter-spacing: 0.12em;
      line-height: 0.95;
      text-transform: uppercase;
      text-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
    }

    .store-catalog {
      padding: 0;
    }

    .store-heading {
      margin: 0 0 34px;
      color: rgba(244, 241, 236, 0.72);
      font-size: 0.78rem;
      font-weight: 400;
      letter-spacing: 0.32em;
      text-align: center;
      text-transform: uppercase;
    }

    .store-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px;
      align-items: stretch;
    }

    .store-card {
      display: flex;
      min-width: 0;
      flex-direction: column;
      gap: 18px;
      align-items: center;
      height: 100%;
      color: #f4f1ec;
      padding: 22px;
      border: 0;
      background: none;
      box-shadow: none;
      backdrop-filter: none;
    }

    .store-card__media {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 340px;
      width: 100%;
      padding: 18px 0 30px;
      overflow: visible;
      background: none;
      box-shadow: none;
    }

    .store-card__stack {
      position: relative;
      width: min(100%, 320px);
      height: 300px;
      padding: 18px 36px 44px;
      overflow: visible;
      box-sizing: border-box;
      isolation: isolate;
    }

    .store-card__stack-link {
      position: relative;
      display: block;
      width: 100%;
      height: 100%;
      color: inherit;
      text-decoration: none;
    }

    .store-card__stack--single {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .store-card__stack-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: contain;
      object-position: center;
      filter: drop-shadow(0 14px 28px rgba(0, 0, 0, 0.32));
      opacity: 0;
      pointer-events: none;
      transition: transform 220ms ease, opacity 220ms ease;
    }

    .store-card__stack-image--single {
      position: relative;
      opacity: 1;
    }

    .store-card__stack-image--back {
      transform: translate(30px, -12px) rotate(8deg) scale(0.86);
      z-index: 1;
      opacity: 0.72;
    }

    .store-card__stack-image--front {
      transform: translate(0, 0) rotate(0deg) scale(1);
      z-index: 3;
      opacity: 1;
    }

    .store-card__stack-image--middle {
      transform: translate(-30px, 16px) rotate(-8deg) scale(0.86);
      z-index: 2;
      opacity: 0.82;
    }

    .store-card:hover .store-card__stack-image--back,
    .store-card:focus-within .store-card__stack-image--back {
      transform: translate(42px, -20px) rotate(10deg) scale(0.86);
    }

    .store-card:hover .store-card__stack-image--middle,
    .store-card:focus-within .store-card__stack-image--middle {
      transform: translate(-42px, 24px) rotate(-10deg) scale(0.86);
    }

    .store-card__stack-nav {
      position: absolute;
      top: 50%;
      z-index: 5;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid rgba(244, 241, 236, 0.34);
      border-radius: 999px;
      color: #f4f1ec;
      background: rgba(0, 0, 0, 0.44);
      font: inherit;
      font-size: 1rem;
      line-height: 1;
      cursor: pointer;
      opacity: 0;
      transform: translateY(-50%);
      transition: opacity 180ms ease, background 180ms ease, color 180ms ease, border-color 180ms ease;
      backdrop-filter: blur(6px);
    }

    .store-card__stack-nav:hover,
    .store-card__stack-nav:focus-visible {
      border-color: rgba(255, 255, 255, 0.85);
      color: #050505;
      background: rgba(255, 255, 255, 0.92);
    }

    .store-card:hover .store-card__stack-nav,
    .store-card:focus-within .store-card__stack-nav,
    .store-card__stack-nav:focus-visible {
      opacity: 1;
    }

    .store-card__stack-nav--prev {
      left: 10px;
    }

    .store-card__stack-nav--next {
      right: 10px;
    }

    .store-card__stack-indicator {
      position: absolute;
      left: 50%;
      bottom: 10px;
      z-index: 5;
      display: inline-flex;
      gap: 8px;
      align-items: center;
      justify-content: center;
      min-width: 56px;
      padding: 7px 10px;
      border: 1px solid rgba(244, 241, 236, 0.16);
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.42);
      transform: translateX(-50%);
      backdrop-filter: blur(6px);
    }

    .store-card__stack-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: rgba(244, 241, 236, 0.34);
      transition: transform 180ms ease, background 180ms ease;
    }

    .store-card__stack-dot.is-active {
      background: #f4f1ec;
      transform: scale(1.15);
    }

    .store-card__title,
    .store-heading {
      margin: 0;
      text-transform: uppercase;
    }

    .store-card__title {
      font-size: 1rem;
      letter-spacing: 0.14em;
      line-height: 1.45;
      min-height: calc(1.45em * 2);
      display: flex;
      align-items: flex-start;
      justify-content: center;
      width: 100%;
      text-align: center;
    }

    .store-card__title-link {
      color: inherit;
      text-decoration: none;
    }

    .store-card__title-link:hover,
    .store-card__title-link:focus-visible {
      opacity: 0.86;
    }

    .store-empty {
      margin: 0;
      color: rgba(244, 241, 236, 0.78);
      text-align: center;
    }

    @media (max-width: 820px) {
      .store-experience__content {
        width: min(calc(100% - 28px), 1180px);
        padding-top: 122px;
      }

      .store-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .store-experience__backdrop {
        position: absolute;
        inset: 0 0 auto 0;
        height: 100vh;
      }

      .store-experience__content {
        margin-top: 0;
        padding-top: 108px;
      }

      .store-intro {
        margin-bottom: 28px;
      }

      .store-intro__title {
        max-width: 100%;
        font-size: clamp(2.2rem, 14vw, 4rem);
      }

      .store-grid {
        grid-template-columns: 1fr;
      }

      .store-card__media {
        min-height: 300px;
        padding-bottom: 24px;
      }

      .store-card__stack {
        height: 260px;
        padding: 14px 24px 38px;
      }

      .store-card__stack-image--back {
        transform: translate(20px, -10px) rotate(7deg) scale(0.88);
      }

      .store-card__stack-image--middle {
        transform: translate(-20px, 12px) rotate(-7deg) scale(0.88);
      }
    }
  </style>
</head>
<body class="public-page-template" data-shell-page="public">
  <%- include("../partials/header") %>
  <main id="site-shell-content" class="store-page">
    <section class="store-experience" aria-labelledby="store-title">
      <div class="store-experience__backdrop immersive-hero" aria-hidden="true">
        <video class="immersive-hero__video" autoplay muted loop playsinline>
          <source src="/videos/auhVHS3.mp4" type="video/mp4" />
        </video>
        <div class="immersive-hero__shade"></div>
        <div class="immersive-hero__noise"></div>
      </div>

      <div class="store-experience__content">
        <section class="store-intro">
          <h1 id="store-title" class="store-intro__title">Store</h1>
        </section>

        <section id="store-catalog" class="store-catalog" aria-labelledby="store-heading">
          <h2 id="store-heading" class="store-heading">Available Now</h2>

          <% if (items.length === 0) { %>
            <p class="store-empty">No products are live right now.</p>
          <% } else { %>
            <div class="store-grid">
              <% items.forEach(i => { %>
                <article class="store-card">
                  <% if (i.stacked_images && i.stacked_images.length > 0) { %>
                    <div class="store-card__media">
                      <div class="store-card__stack <%= i.stacked_images.length === 1 ? 'store-card__stack--single' : '' %>">
                        <a href="/product/<%= i.slug %>" class="store-card__stack-link" aria-label="View <%= i.name %>">
                          <% i.stacked_images.forEach((image, index) => { %>
                            <% const stackClass = i.stacked_images.length === 1 ? 'store-card__stack-image--single' : index === 0 ? 'store-card__stack-image--front' : index === 1 ? 'store-card__stack-image--middle' : 'store-card__stack-image--back'; %>
                            <img
                              class="store-card__stack-image <%= stackClass %>"
                              src="<%= image.image_path %>"
                              alt="<%= image.alt_text || i.name %>"
                            >
                          <% }) %>
                        </a>
                        <% if (i.stacked_images.length > 1) { %>
                          <button type="button" class="store-card__stack-nav store-card__stack-nav--prev" aria-label="Show previous product image">&#8249;</button>
                          <button type="button" class="store-card__stack-nav store-card__stack-nav--next" aria-label="Show next product image">&#8250;</button>
                          <div class="store-card__stack-indicator" aria-hidden="true">
                            <% i.stacked_images.forEach((_, index) => { %>
                              <span class="store-card__stack-dot <%= index === 0 ? 'is-active' : '' %>"></span>
                            <% }) %>
                          </div>
                        <% } %>
                      </div>
                    </div>
                  <% } %>
                  <h3 class="store-card__title"><a href="/product/<%= i.slug %>" class="store-card__title-link"><%= i.name %></a></h3>
                </article>
              <% }) %>
            </div>
          <% } %>
        </section>
      </div>
    </section>
  </main>
  <%- include("../partials/public_shell_bootstrap") %>
</body>
</html>
