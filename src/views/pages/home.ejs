<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style id="site-page-styles">
<%- include("../partials/public_page_styles") %>
<%- include("../partials/immersive_hero_styles") %>

    .home-page {
      --latest-trigger-height: 26px;
      --release-art-size: clamp(220px, 18vw, 324px);
      position: relative;
      background: #050505;
      height: 100vh;
      overflow: hidden;
    }

    .home-template {
      overflow: hidden;
    }

    .home-template .site-header__cart-link,
    .home-template .site-audio__button,
    .home-template .site-audio__slider,
    .home-template .site-header__desktop-nav a {
      color: rgba(244, 241, 236, 0.88);
    }

    .home-template .site-audio__button {
      border-color: rgba(244, 241, 236, 0.42);
      background: rgba(0, 0, 0, 0.22);
    }

    .home-template .site-audio__slider {
      opacity: 0.86;
    }

    .home-experience {
      position: relative;
      height: 100vh;
    }

    .home-experience__backdrop {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: hidden;
      background: #000;
    }

    .home-experience__backdrop::after {
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(0, 0, 0, 0.16), rgba(0, 0, 0, 0.38));
      content: "";
      z-index: -1;
      pointer-events: none;
    }

    .home-experience__content {
      position: absolute;
      inset: 0;
      z-index: 2;
      width: 100%;
      pointer-events: none;
    }

    .home-intro {
      position: relative;
      min-height: 100vh;
    }

    .home-intro__anchor {
      position: relative;
      z-index: 3;
      align-self: center;
      padding: 0;
      border: 0;
      background: transparent;
      color: rgba(255, 255, 255, 0.72);
      font: inherit;
      min-height: var(--latest-trigger-height);
      font-size: 0.62rem;
      letter-spacing: 0.28em;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.8);
      text-transform: uppercase;
      transition: opacity 180ms ease, color 180ms ease;
      pointer-events: auto;
      cursor: pointer;
    }

    .home-intro__anchor:hover,
    .home-intro__anchor:focus-visible {
      opacity: 1;
      color: #fff;
    }

    .latest-section {
      position: absolute;
      left: 50%;
      bottom: 22px;
      width: min(1280px, calc(100% - 24px));
      max-height: var(--latest-trigger-height);
      overflow: hidden;
      transform: translateX(-50%);
      transition: max-height 320ms ease;
      pointer-events: auto;
    }

    .latest-section__inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 18px;
      width: 100%;
      margin: 0 auto;
      padding: 0;
    }

    .home-page--latest-open .latest-section {
      max-height: calc(var(--release-art-size) + 160px);
    }

    .latest-grid {
      display: grid;
      grid-template-columns: auto auto auto;
      gap: 16px;
      align-items: start;
      justify-content: center;
    }

    .latest-card {
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      min-width: 0;
      color: #f4f1ec;
      background: transparent;
    }

    .latest-card--release {
      width: var(--release-art-size);
    }

    .latest-card--video {
      width: calc(var(--release-art-size) * 16 / 9);
      align-items: center;
    }

    .latest-card__media {
      width: 100%;
      height: var(--release-art-size);
      overflow: hidden;
      background: transparent;
    }

    .latest-card__media img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .latest-card__media--video {
      width: 100%;
      height: var(--release-art-size);
      background: #000;
    }

    .latest-card__media--video iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }

    .latest-card__body {
      display: flex;
      flex: 1;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      width: 100%;
      padding: 10px 4px 0;
      justify-content: flex-start;
      text-align: center;
    }

    .latest-card__title {
      margin: 0;
      min-height: 2.5em;
      font-size: clamp(0.7rem, 0.95vw, 0.84rem);
      line-height: 1.2;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 28px;
      padding: 6px 11px;
      border: 1px solid currentColor;
      border-radius: 4px;
      color: #f4f1ec;
      font-size: 0.52rem;
      line-height: 1;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      transition: background 180ms ease, color 180ms ease, opacity 180ms ease;
      margin-top: auto;
    }

    .button:hover,
    .button:focus-visible {
      background: #f4f1ec;
      color: #050505;
    }

    @media (max-width: 1100px) {
      .latest-grid {
        grid-template-columns: 1fr;
      }

      .latest-card--release,
      .latest-card__media--video {
        width: 100%;
      }

      .latest-card--video {
        width: min(100%, 576px);
      }

      .latest-card__media img {
        aspect-ratio: auto;
      }
    }

    @media (max-width: 820px) {
      .latest-section {
        width: min(700px, calc(100% - 28px));
        bottom: 20px;
      }
    }

    @media (max-width: 640px) {
      .home-experience__backdrop {
        position: absolute;
        inset: 0 0 auto 0;
        height: 100vh;
      }

      .latest-section {
        bottom: 18px;
        width: min(420px, calc(100% - 24px));
      }

      .latest-card__body {
        padding: 12px 4px 0;
      }
    }
  </style>
</head>
<body class="public-page-template home-template" data-shell-page="public">
  <%- include("../partials/header") %>

  <main id="site-shell-content" class="home-page">
    <section class="home-experience" aria-labelledby="latest-release-heading">
      <div class="home-experience__backdrop immersive-hero" aria-hidden="true">
        <video class="immersive-hero__video" autoplay muted loop playsinline>
          <source src="/videos/auhVHStitle.mp4" type="video/mp4" />
        </video>
        <div class="immersive-hero__shade"></div>
        <div class="immersive-hero__noise"></div>
      </div>

      <div class="home-experience__content">
        <section class="home-intro" aria-label="Homepage hero">
          <section id="latest-release" class="latest-section" aria-labelledby="latest-release-heading">
          <div class="latest-section__inner">
            <button type="button" class="home-intro__anchor" id="latestReleaseToggle" aria-expanded="false">
              Latest Releases
            </button>

            <div class="latest-grid">
              <article class="latest-card latest-card--release">
                <div class="latest-card__media">
                  <img
                    src="/images/auh-highCover.jpg"
                    alt="Moving On / Someone You Adore cover art"
                  />
                </div>

                <div class="latest-card__body">
                  <h3 class="latest-card__title">Moving On / Someone You Adore</h3>
                  <a
                    href="https://dthw.sh/allunderheavenhigh"
                    class="button"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Listen Now
                  </a>
                </div>
              </article>

              <article class="latest-card latest-card--release">
                <div class="latest-card__media">
                  <img
                    src="/images/AllUnderHeaven-WhatLiesAheadOfMe-Cover_2000x.jpg"
                    alt="What Lies Ahead of Me cover art"
                  />
                </div>

                <div class="latest-card__body">
                  <h3 class="latest-card__title">What Lies Ahead of Me</h3>
                  <a
                    href="https://dthw.sh/whatliesaheadofme"
                    class="button"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Listen Now
                  </a>
                </div>
              </article>

              <article class="latest-card latest-card--video">
                <div class="latest-card__media latest-card__media--video">
                  <iframe
                    src="https://www.youtube.com/embed/tv4bOfoLtew"
                    title="all under heaven on Audiotree Live"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    referrerpolicy="strict-origin-when-cross-origin"
                    allowfullscreen
                  ></iframe>
                </div>

                <div class="latest-card__body">
                  <h3 class="latest-card__title">Audiotree Live</h3>
                </div>
              </article>
            </div>
          </div>
          </section>
        </section>
      </div>
    </section>
  </main>
  <%- include("../partials/public_shell_bootstrap") %>
</body>
</html>
