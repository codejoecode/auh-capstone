<!doctype html>
<html>
<head><meta charset="utf-8"><title><%= title %></title><%- include("../partials/admin_shell_styles") %></head>
<body>
  <%- include("../partials/header") %>
  <main class="admin-page">
    <section class="page-intro">
      <h1><%= title %></h1>
      <p>Update product details, ticket settings, images, and variants from one place.</p>
    </section>

    <section class="admin-card">
      <% if (error) { %>
        <p class="error-banner"><strong><%= error %></strong></p>
      <% } %>

      <form action="/admin/products/<%= product.id %>/edit" method="POST" id="editProductForm" class="split-stack">
        <div>
          <div class="section-title">
            <h2>Product Basics</h2>
            <p>Edit the public-facing details and internal product settings here.</p>
          </div>

          <div class="form-grid">
            <div class="field-block">
              <label for="nameInput">Name</label>
              <input name="name" id="nameInput" value="<%= product.name %>" required>
              <span class="muted-text" id="nameHelp"><%= product.type === "ticket" ? "Auto-generated from ticket city and state." : "Used as the product title on the storefront." %></span>
            </div>

            <div class="field-block">
              <label for="slugInput">Slug</label>
              <input
                name="slug"
                id="slugInput"
                value="<%= product.slug %>"
                pattern="[a-z0-9]+(?:-[a-z0-9]+)*"
                title="Use lowercase letters, numbers, and hyphens only."
                autocapitalize="off"
                autocomplete="off"
                spellcheck="false"
                required
              >
            </div>

            <div class="field-block">
              <label for="typeSelect">Type</label>
              <select name="type" id="typeSelect" required>
                <option value="ticket" <%= product.type === "ticket" ? "selected" : "" %>>ticket</option>
                <option value="merch" <%= product.type === "merch" ? "selected" : "" %>>merch</option>
              </select>
            </div>

            <div class="field-block">
              <label for="imageUrlInput">Image URL (legacy fallback)</label>
              <input name="imageUrl" id="imageUrlInput" value="<%= product.image_url || "" %>">
            </div>

            <div class="field-block full">
              <label for="descriptionInput">Description</label>
              <textarea name="description" id="descriptionInput" rows="4"><%= product.description || "" %></textarea>
            </div>
          </div>
        </div>

        <div id="ticketFields" class="subsection">
          <div class="section-title">
            <h2>Ticket Details</h2>
            <p>These fields only apply when the product type is a ticket.</p>
          </div>

          <div class="form-grid">
            <div class="field-block">
              <label for="eventDateInput">Event date</label>
              <input name="eventDate" id="eventDateInput" type="datetime-local" value="<%= product.event_date || "" %>">
            </div>

            <div class="field-block">
              <label for="venueNameInput">Venue name</label>
              <input name="venueName" id="venueNameInput" value="<%= product.venue_name || "" %>">
            </div>

            <div class="field-block">
              <label for="venueCityInput">Venue city</label>
              <input name="venueCity" id="venueCityInput" value="<%= product.venue_city || "" %>">
            </div>

            <div class="field-block">
              <label for="venueStateInput">Venue state</label>
              <input name="venueState" id="venueStateInput" value="<%= product.venue_state || "" %>">
            </div>

            <div class="field-block">
              <label for="ticketModeSelect">Ticket mode</label>
              <select name="ticketMode" id="ticketModeSelect">
                <option value="internal" <%= product.ticket_mode === "internal" ? "selected" : "" %>>internal</option>
                <option value="external" <%= product.ticket_mode === "external" ? "selected" : "" %>>external</option>
                <option value="doors_only" <%= product.ticket_mode === "doors_only" ? "selected" : "" %>>doors_only</option>
                <option value="free" <%= product.ticket_mode === "free" ? "selected" : "" %>>free</option>
              </select>
            </div>

            <div class="field-block" id="externalUrlWrap">
              <label for="externalUrlInput" id="externalUrlLabel">External URL</label>
              <input name="externalUrl" id="externalUrlInput" value="<%= product.external_url || "" %>">
            </div>

            <div class="field-block full inline">
              <label>
                <input name="isOnSale" type="checkbox" value="1" <%= product.is_on_sale ? "checked" : "" %>>
                On sale
              </label>
            </div>

            <div class="field-block full">
              <p class="muted-text" id="ticketModeHelp"></p>
            </div>
          </div>
        </div>

        <div class="admin-actions">
          <button type="submit">Save Changes</button>
          <a href="/admin/products" class="admin-link-button secondary">Back</a>
        </div>
      </form>
    </section>

    <% if (product.type === "merch") { %>
      <section class="admin-card">
        <div class="section-title">
          <h2>Merch Images</h2>
          <p>Upload gallery images and assign them to variants when needed.</p>
        </div>

        <% if (imageError) { %>
          <p class="error-banner"><strong><%= imageError %></strong></p>
        <% } %>

        <form action="/admin/products/<%= product.id %>/images/upload" method="POST" enctype="multipart/form-data" class="form-grid single-column">
          <div class="field-block full">
            <label for="imagesUploadInput">Upload images</label>
            <input id="imagesUploadInput" type="file" name="images" accept="image/jpeg,image/png,image/webp" multiple required>
          </div>
          <div class="admin-actions">
            <button type="submit">Upload Images</button>
          </div>
        </form>

        <% if (productImages.length === 0) { %>
          <p class="empty-state">No uploaded merch images yet. The legacy product image URL will still work as a fallback.</p>
        <% } else { %>
          <div class="admin-table-wrap">
            <table class="admin-table">
        <tr>
          <th>Preview</th>
          <th>Stored path</th>
          <th>Settings</th>
          <th>Delete</th>
        </tr>
        <% productImages.forEach((image) => { %>
          <tr>
            <td>
              <img src="<%= image.image_path %>" alt="<%= image.alt_text || product.name %>" style="width:120px;height:120px;object-fit:cover;">
            </td>
            <td style="max-width:260px;word-break:break-all;"><%= image.image_path %></td>
            <td>
              <form action="/admin/products/<%= product.id %>/images/<%= image.id %>/update" method="POST" class="form-grid single-column">
                <div class="field-block full">
                  <label>Alt text</label>
                  <input name="altText" value="<%= image.alt_text || "" %>">
                </div>

                <div class="field-block full">
                  <label>Sort order</label>
                  <input name="sortOrder" type="number" value="<%= image.sort_order %>">
                </div>

                <div class="field-block full inline">
                  <label>
                    <input name="isActive" type="checkbox" value="1" <%= image.is_active ? "checked" : "" %>>
                    Active
                  </label>
                </div>

                <div class="field-block full inline">
                  <label>
                    <input name="isPrimary" type="checkbox" value="1" <%= image.is_primary ? "checked" : "" %>>
                    Primary image
                  </label>
                </div>

                <div class="field-block full">
                  <label>Variant image for</label>
                  <select name="variantId">
                    <option value="">Product gallery image</option>
                    <% variants.forEach((variant) => { %>
                      <option value="<%= variant.id %>" <%= Number(image.variant_id) === Number(variant.id) ? "selected" : "" %>>
                        <%= variant.name %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <div class="admin-actions">
                  <button type="submit">Save Image Settings</button>
                </div>
              </form>
            </td>
            <td>
              <form action="/admin/products/<%= product.id %>/images/<%= image.id %>/delete" method="POST">
                <button type="submit" class="secondary">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
            </table>
          </div>
        <% } %>
      </section>
    <% } %>

    <section class="admin-card">
      <div class="section-title">
        <h2>Variants</h2>
        <p>Adjust existing variants or add a new one below.</p>
      </div>

      <% if (variants.length === 0) { %>
        <p class="empty-state">No variants yet.</p>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
      <tr>
        <th>Name</th>
        <th>Price (cents)</th>
        <th>Stock</th>
        <th>Active</th>
        <th>Actions</th>
      </tr>
      <% variants.forEach(variant => { %>
        <tr>
          <td>
            <form action="/admin/products/<%= product.id %>/variants/<%= variant.id %>/edit" method="POST">
              <input name="name" value="<%= variant.name %>" required>
          </td>
          <td>
              <input name="priceCents" type="number" min="1" value="<%= variant.price_cents %>" required>
          </td>
          <td>
              <input name="stockQty" type="number" min="0" value="<%= variant.stock_qty %>" required>
          </td>
          <td><%= variant.is_active ? "Active" : "Inactive" %></td>
          <td>
              <div class="table-actions">
                <button type="submit">Save</button>
            </form>
                <form action="/admin/products/<%= product.id %>/variants/<%= variant.id %>/toggle" method="POST">
                  <button type="submit" class="secondary"><%= variant.is_active ? "Deactivate" : "Activate" %></button>
                </form>
              </div>
          </td>
        </tr>
      <% }) %>
          </table>
        </div>
      <% } %>

      <div class="subsection">
        <h3>Add Variant</h3>

        <% if (variantError) { %>
          <p class="error-banner"><strong><%= variantError %></strong></p>
        <% } %>

        <form action="/admin/products/<%= product.id %>/variants/new" method="POST" class="form-grid">
          <div class="field-block">
            <label>Variant Name</label>
            <input name="name" required>
          </div>

          <div class="field-block">
            <label>Price (cents)</label>
            <input name="priceCents" type="number" min="1" placeholder="2500" required>
          </div>

          <div class="field-block">
            <label>Stock quantity</label>
            <input name="stockQty" type="number" min="0" placeholder="25" required>
          </div>

          <div class="field-block full">
            <div class="admin-actions">
              <button type="submit">Add Variant</button>
              <a href="/admin/products" class="admin-link-button secondary">Back</a>
            </div>
          </div>
        </form>
      </div>
    </section>
  </main>

  <script>
    const nameInput = document.getElementById("nameInput");
    const nameHelp = document.getElementById("nameHelp");
    const slugInput = document.getElementById("slugInput");
    const typeSelect = document.getElementById("typeSelect");
    const ticketModeSelect = document.getElementById("ticketModeSelect");
    const ticketFields = document.getElementById("ticketFields");
    const ticketModeHelp = document.getElementById("ticketModeHelp");
    const externalUrlWrap = document.getElementById("externalUrlWrap");
    const externalUrlLabel = document.getElementById("externalUrlLabel");
    const eventDateInput = document.getElementById("eventDateInput");
    const venueNameInput = document.getElementById("venueNameInput");
    const venueCityInput = document.getElementById("venueCityInput");
    const venueStateInput = document.getElementById("venueStateInput");
    const externalUrlInput = document.getElementById("externalUrlInput");
    let slugEditedManually = false;

    function slugify(value) {
      return String(value || "")
        .normalize("NFKD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "")
        .replace(/-{2,}/g, "-");
    }

    function formatTicketName() {
      return [venueCityInput.value.trim(), venueStateInput.value.trim()].filter(Boolean).join(", ");
    }

    function formatTicketSlugSource() {
      const eventDate = eventDateInput.value.trim().slice(0, 10);
      return ["auh", venueCityInput.value.trim(), eventDate].filter(Boolean).join("-");
    }

    function syncSlugEditedState() {
      const currentSlug = slugify(slugInput.value);
      const generatedSlug = typeSelect.value === "ticket"
        ? slugify(formatTicketSlugSource() || formatTicketName())
        : slugify(nameInput.value);
      slugEditedManually = Boolean(currentSlug) && currentSlug !== generatedSlug;
    }

    function syncSlugFromName(force = false) {
      const generatedSlug = typeSelect.value === "ticket"
        ? slugify(formatTicketSlugSource() || formatTicketName())
        : slugify(nameInput.value);
      const currentSlug = slugify(slugInput.value);

      if (force || !slugEditedManually || !currentSlug) {
        slugInput.value = generatedSlug;
        slugEditedManually = false;
      }
    }

    function syncTicketIdentity(forceSlug = false) {
      const isTicket = typeSelect.value === "ticket";

      nameInput.readOnly = isTicket;
      nameHelp.textContent = isTicket
        ? "Auto-generated from ticket city and state."
        : "Used as the product title on the storefront.";

      if (!isTicket) {
        return;
      }

      nameInput.value = formatTicketName();
      syncSlugFromName(forceSlug);
    }

    function syncTicketFields() {
      const isTicket = typeSelect.value === "ticket";
      const isExternal = isTicket && ticketModeSelect.value === "external";

      ticketFields.style.display = isTicket ? "block" : "none";
      externalUrlWrap.style.display = isTicket ? "block" : "none";
      externalUrlLabel.textContent = isExternal ? "External URL" : "External URL (only used for external mode)";

      eventDateInput.required = isTicket;
      venueNameInput.required = isTicket;
      venueCityInput.required = isTicket;
      venueStateInput.required = isTicket;
      ticketModeSelect.required = isTicket;
      externalUrlInput.required = isExternal;

      if (!isTicket) {
        ticketModeHelp.textContent = "";
      } else if (ticketModeSelect.value === "internal") {
        ticketModeHelp.textContent = "Internal tickets use the variant table below for pricing and inventory.";
      } else {
        ticketModeHelp.textContent = "Non-internal ticket modes do not require variants, but existing variants are preserved.";
      }

      syncTicketIdentity();
    }

    nameInput.addEventListener("input", () => {
      syncSlugFromName();
    });

    slugInput.addEventListener("input", () => {
      const normalizedSlug = slugify(slugInput.value);
      if (slugInput.value !== normalizedSlug) {
        slugInput.value = normalizedSlug;
      }

      if (!slugInput.value) {
        slugEditedManually = false;
        return;
      }

      syncSlugEditedState();
    });

    slugInput.addEventListener("blur", () => {
      if (!slugInput.value.trim()) {
        syncSlugFromName(true);
      }
    });

    eventDateInput.addEventListener("input", () => {
      syncTicketIdentity();
    });

    venueCityInput.addEventListener("input", () => {
      syncTicketIdentity();
    });

    venueStateInput.addEventListener("input", () => {
      syncTicketIdentity();
    });

    typeSelect.addEventListener("change", () => {
      if (typeSelect.value === "ticket") {
        slugEditedManually = false;
      }

      syncTicketFields();
    });
    ticketModeSelect.addEventListener("change", syncTicketFields);
    document.getElementById("editProductForm").addEventListener("submit", () => {
      if (!slugInput.value.trim()) {
        syncSlugFromName(true);
      } else {
        slugInput.value = slugify(slugInput.value);
      }
    });

    slugInput.value = slugify(slugInput.value);
    syncSlugEditedState();
    syncTicketIdentity(true);
    syncTicketFields();
  </script>
</body>
</html>
