<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style id="site-page-styles">
    * {
      box-sizing: border-box;
    }

    html,
    body {
      min-height: 100%;
    }

    body.intro-template {
      margin: 0;
      background: #050505;
      color: #f4f1ec;
      font-family: Arial, sans-serif;
      line-height: 1.5;
    }

    img {
      display: block;
      max-width: 100%;
      height: auto;
    }

    a {
      color: inherit;
    }

<%- include("../partials/immersive_hero_styles") %>

    .site-shell-header {
      display: none;
    }

    .intro-hero__content {
      position: relative;
      z-index: 2;
      display: flex;
      min-height: 100vh;
      align-items: center;
      justify-content: center;
      padding: 32px 20px;
    }

    .intro-hero__stack {
      display: flex;
      width: min(540px, 100%);
      flex-direction: column;
      align-items: center;
      gap: 32px;
      text-align: center;
    }

    .intro-hero__logo {
      width: min(540px, 100%);
      filter: brightness(0) invert(1);
      opacity: 0.94;
    }

    .intro-hero__enter {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 12px 26px;
      border: 1px solid rgba(255, 255, 255, 0.76);
      border-radius: 4px;
      color: rgba(255, 255, 255, 0.86);
      font-size: 0.72rem;
      letter-spacing: 0.28em;
      text-decoration: none;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.8);
      text-transform: uppercase;
      transition: background 180ms ease, color 180ms ease, opacity 180ms ease;
    }

    .intro-hero__enter:hover,
    .intro-hero__enter:focus-visible {
      background: #fff;
      color: #050505;
      opacity: 1;
    }

    @media (max-width: 560px) {
      .intro-hero__stack {
        gap: 24px;
      }

      .intro-hero__logo {
        width: min(320px, 100%);
      }
    }
  </style>
</head>
<body class="intro-template" data-shell-page="intro">
  <%- include("../partials/header") %>

  <main id="site-shell-content" class="intro-page">
    <section class="intro-hero immersive-hero" aria-label="All Under Heaven intro">
      <video class="intro-hero__video immersive-hero__video" autoplay muted loop playsinline aria-hidden="true">
        <source src="/videos/auhVHSintro.mp4" type="video/mp4" />
      </video>

      <div class="intro-hero__shade immersive-hero__shade" aria-hidden="true"></div>
      <div class="intro-hero__noise immersive-hero__noise" aria-hidden="true"></div>

      <div class="intro-hero__content">
        <div class="intro-hero__stack">
          <img
            class="intro-hero__logo"
            src="/images/all-under-heaven-logo-wide.svg"
            alt="All Under Heaven"
          />

          <a href="/home" class="intro-hero__enter" data-intro-enter>Enter</a>
        </div>
      </div>
    </section>
  </main>

  <%- include("../partials/public_shell_bootstrap") %>
</body>
</html>
