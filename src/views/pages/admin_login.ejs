<!doctype html>
<html>
<head><meta charset="utf-8"><title><%= title %></title><%- include("../partials/admin_shell_styles") %></head>
<body>
  <%- include("../partials/header") %>
  <main class="admin-page narrow">
    <section class="page-intro">
      <h1><%= title %></h1>
      <p>Use the admin password to access product, order, and newsletter controls.</p>
    </section>

    <section class="admin-card">
      <% if (error) { %>
        <p class="error-banner"><strong><%= error %></strong></p>
      <% } %>

      <form action="/admin/login" method="POST" class="form-grid single-column">
        <div class="field-block full">
          <label for="adminPassword">Password</label>
          <input id="adminPassword" type="password" name="password" placeholder="Admin password" required>
        </div>

        <div class="admin-actions">
          <button type="submit">Log in</button>
          <a href="/home" class="admin-link-button secondary">Home</a>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
