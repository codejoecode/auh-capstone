<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <style id="site-page-styles">
<%- include("../partials/public_page_styles") %>

    .music-page {
      background: #050505;
    }

    .music-hero {
      position: relative;
      min-height: 100vh;
      height: 100vh;
      padding: 128px 20px 92px;
      overflow: hidden;
      isolation: isolate;
      background: #000;
    }

    .music-hero::after {
      position: absolute;
      right: 0;
      bottom: 0;
      left: 0;
      height: 120px;
      background: linear-gradient(to bottom, rgba(5, 5, 5, 0), rgba(5, 5, 5, 0.88));
      content: "";
      pointer-events: none;
      z-index: 1;
    }

    .music-hero__video,
    .music-hero__shade,
    .music-hero__noise {
      position: absolute;
      inset: 0;
    }

    .music-hero__video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: saturate(1) contrast(1) brightness(1);
      transform: scale(1.04);
      z-index: -3;
    }

    .music-hero__shade {
      background:
        radial-gradient(circle at 68% 42%, rgba(255, 255, 255, 0.14), transparent 32%),
        linear-gradient(90deg, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.5) 58%, rgba(0, 0, 0, 0.76));
      z-index: -2;
    }

    .music-hero__noise {
      background-image: url("/images/animatedBackground.gif");
      background-repeat: repeat;
      opacity: 0.12;
      mix-blend-mode: screen;
      pointer-events: none;
      z-index: -1;
    }

    .music-hero__anchor {
      position: absolute;
      left: 50%;
      bottom: 28px;
      z-index: 2;
      color: rgba(255, 255, 255, 0.72);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-decoration: none;
      text-shadow: 0 2px 14px rgba(0, 0, 0, 0.8);
      text-transform: uppercase;
      transform: translateX(-50%);
      transition: opacity 180ms ease, color 180ms ease;
    }

    .music-hero__anchor:hover,
    .music-hero__anchor:focus-visible {
      opacity: 1;
      color: #fff;
    }

    .featured-release {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: minmax(220px, 430px) minmax(0, 1fr);
      gap: clamp(28px, 6vw, 92px);
      align-items: center;
      width: min(1120px, 100%);
      min-height: calc(min(820px, 88vh) - 214px);
      margin: 0 auto;
    }

    .featured-release__art {
      background: #000;
      border: 1px solid rgba(255, 255, 255, 0.2);
      box-shadow: 0 28px 70px rgba(0, 0, 0, 0.62);
    }

    .featured-release__art img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
    }

    .featured-info {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      color: #fff;
    }

    .featured-label,
    .section-header p {
      margin: 0;
      color: rgba(244, 241, 236, 0.58);
      font-size: 0.68rem;
      letter-spacing: 0.28em;
      text-transform: uppercase;
    }

    .featured-info h1,
    .album-info h3,
    .section-header h2 {
      margin: 0;
      text-transform: uppercase;
      letter-spacing: 0.12em;
    }

    .featured-info h1 {
      max-width: 13em;
      font-size: clamp(1.4rem, 4vw, 4.6rem);
      line-height: 1.03;
    }

    .discography-section {
      padding: 84px 20px 96px;
      background: #050505;
    }

    .discography-section__inner {
      width: min(1120px, 100%);
      margin: 0 auto;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      gap: 24px;
      align-items: end;
      margin-bottom: 34px;
      padding-bottom: 18px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    }

    .section-header h2 {
      font-size: clamp(1rem, 2vw, 1.8rem);
      font-weight: 400;
    }

    .button {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      padding: 10px 22px;
      border: 1px solid currentColor;
      border-radius: 4px;
      color: #f4f1ec;
      font-size: 0.72rem;
      line-height: 1;
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      transition: background 180ms ease, color 180ms ease, opacity 180ms ease;
    }

    .button:hover,
    .button:focus-visible {
      background: #f4f1ec;
      color: #050505;
    }

    .button-small {
      padding: 8px 16px;
      min-height: 38px;
    }

    .album-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: clamp(18px, 3vw, 42px);
      align-items: start;
    }

    .album-card {
      display: flex;
      min-width: 0;
      flex-direction: column;
      gap: 18px;
      color: #f4f1ec;
    }

    .album-card img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: cover;
      border: 1px solid rgba(255, 255, 255, 0.18);
    }

    .album-info {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .album-info h3 {
      min-height: 3.1em;
      font-size: 0.9rem;
      line-height: 1.55;
    }

    @media (max-width: 820px) {
      .music-hero {
        min-height: 100vh;
        height: auto;
        padding: 104px 18px 86px;
      }

      .featured-release {
        grid-template-columns: 1fr;
        min-height: 0;
        max-width: 560px;
        gap: 28px;
      }

      .featured-info {
        align-items: center;
        text-align: center;
      }

      .section-header {
        display: block;
      }

      .section-header h2 {
        margin-bottom: 10px;
      }

      .album-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .music-hero {
        padding-top: 92px;
      }

      .discography-section {
        padding-top: 64px;
      }

      .album-grid {
        grid-template-columns: 1fr;
        gap: 52px;
      }

      .album-info h3 {
        min-height: 0;
      }
    }
  </style>
</head>
<body class="public-page-template music-template" data-shell-page="public">
  <%- include("../partials/header") %>

  <main id="site-shell-content" class="music-page">
    <section class="music-hero" aria-label="Featured music release">
      <video class="music-hero__video" autoplay muted loop playsinline aria-hidden="true">
        <source src="/videos/auhVHS2.mp4" type="video/mp4" />
      </video>

      <div class="music-hero__shade" aria-hidden="true"></div>
      <div class="music-hero__noise" aria-hidden="true"></div>

      <article class="featured-release">
        <div class="featured-release__art">
          <img src="/images/auh-highCover.jpg" alt="AUH / High. Cover" />
        </div>

        <div class="featured-info">
          <p class="featured-label">Featured Release</p>
          <h1>MOVING ON</h1>
          <a
            href="https://dthw.sh/allunderheavenhigh"
            class="button"
            target="_blank"
            rel="noopener noreferrer"
          >
            Listen Now
          </a>
        </div>
      </article>

      <a href="#discography" class="music-hero__anchor">DISCOGRAPHY</a>
    </section>

    <section id="discography" class="discography-section">
      <div class="discography-section__inner">
        <header class="section-header">
          <h2>Discography</h2>
          <p>Archive</p>
        </header>

        <div class="album-grid">
          <article class="album-card">
            <img
              src="/images/AllUnderHeaven-WhatLiesAheadOfMe-Cover_2000x.jpg"
              alt="What Lies Ahead of Me Cover"
            />

            <div class="album-info">
              <h3>What Lies Ahead of Me</h3>
              <a
                href="https://dthw.sh/whatliesaheadofme"
                class="button button-small"
                target="_blank"
                rel="noopener noreferrer"
              >
                Listen Now
              </a>
            </div>
          </article>

          <article class="album-card">
            <img
              src="/images/auh-lt-glareCover.jpg"
              alt="AUH / Leaving Time / Glare Cover"
            />

            <div class="album-info">
              <h3>Split</h3>
              <a
                href="https://open.spotify.com/album/3G7HgD4vxg04rSF1WXYTFM?si=Ne2mcetvQZCGIugmD986KA"
                class="button button-small"
                target="_blank"
                rel="noopener noreferrer"
              >
                Listen Now
              </a>
            </div>
          </article>

          <article class="album-card">
            <img
              src="/images/dsa2acCover.jpg"
              alt="Don't Suffer Alone / Alley Cat Cover"
            />

            <div class="album-info">
              <h3>Don't Suffer Alone / Alley Cat</h3>
              <a
                href="https://linktr.ee/allunderheaven"
                class="button button-small"
                target="_blank"
                rel="noopener noreferrer"
              >
                Listen Now
              </a>
            </div>
          </article>

          <article class="album-card">
            <img
              src="/images/colliderCover.jpg"
              alt="Collider Cover"
            />

            <div class="album-info">
              <h3>Collider</h3>
              <a
                href="https://linktr.ee/allunderheaven"
                class="button button-small"
                target="_blank"
                rel="noopener noreferrer"
              >
                Listen Now
              </a>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>
  <%- include("../partials/public_shell_bootstrap") %>
</body>
</html>
