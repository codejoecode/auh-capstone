<!doctype html>
<html>
<head><meta charset="utf-8"><title><%= title %></title><%- include("../partials/admin_shell_styles") %></head>
<body>
  <%- include("../partials/header") %>
  <main class="admin-page">
    <section class="page-intro">
      <h1><%= title %></h1>
      <p>Track recent purchases and open full order details when needed.</p>
    </section>

    <section class="admin-card">
      <div class="stats-grid">
        <div class="stat-card">
          <span>Total orders</span>
          <strong><%= orders.length %></strong>
        </div>
      </div>

      <div class="admin-actions">
        <a href="/admin" class="admin-link-button secondary">Back to Admin</a>
      </div>
    </section>

    <section class="admin-card">
      <% if (orders.length === 0) { %>
        <p class="empty-state">No orders yet.</p>
      <% } else { %>
        <div class="admin-table-wrap">
          <table class="admin-table">
            <tr>
              <th>Order Number</th>
              <th>Customer Name</th>
              <th>Customer Email</th>
              <th>Subtotal</th>
              <th>Status</th>
              <th>Created At</th>
              <th>Actions</th>
            </tr>
            <% orders.forEach(order => { %>
              <tr>
                <td><%= order.order_number %></td>
                <td><%= order.customer_name %></td>
                <td><%= order.customer_email %></td>
                <td>$<%= (order.subtotal_cents / 100).toFixed(2) %></td>
                <td><%= order.status %></td>
                <td><%= order.created_at %></td>
                <td><a href="/admin/orders/<%= order.id %>">View Details</a></td>
              </tr>
            <% }) %>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
