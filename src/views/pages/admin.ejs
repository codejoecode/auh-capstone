<!doctype html>
<html>
<head><meta charset="utf-8"><title><%= title %></title><%- include("../partials/admin_shell_styles") %></head>
<body>
  <%- include("../partials/header") %>
  <main class="admin-page narrow">
    <section class="page-intro">
      <h1><%= title %></h1>
      <p>Everything admin-related, organized in one place.</p>
    </section>

    <section class="admin-card">
      <div class="section-title">
        <h2>Quick Access</h2>
        <p>Jump straight to the main areas of the admin panel.</p>
      </div>

      <ul class="stack-list">
        <li><a href="/admin/products">Manage Products (Tickets + Merch)</a></li>
        <li><a href="/admin/orders">View Orders</a></li>
        <li><a href="/admin/newsletter">Manage Newsletter Signups</a></li>
        <li><a href="/tickets">View Tickets Page</a></li>
        <li><a href="/store">View Store Page</a></li>
      </ul>

      <div class="admin-actions">
        <form action="/admin/logout" method="POST">
          <button type="submit">Log out</button>
        </form>
      </div>
    </section>
  </main>
</body>
</html>
